# Allow www-data (nginx/fcgiwrap) to manage the wisd-xray service via systemctl.
# Installed into /etc/sudoers.d/wisd-cgi by deploy/install.sh.
www-data ALL=(root) NOPASSWD: /usr/bin/systemctl start wisd-xray.service, /usr/bin/systemctl stop wisd-xray.service, /usr/bin/systemctl restart wisd-xray.service, /usr/bin/systemctl status wisd-xray.service
